{
  "name": "react-static-starter-kit",
  "version": "26.3.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "http-server build -p ${PORT:-8080}",
    "clean": "rimraf build test-results coverage",
    "prebuild": "npm run clean && npm run lint && npm run typecheck",
    "build": "vite build",
    "dev": "vite dev",
    "test": "npm run test:unit",
    "test:unit": "vitest run src/** --coverage",
    "test:integration": "vitest run tests/**",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint && stylelint src/**/*.css",
    "lint:fix": "eslint --fix && stylelint src/**/*.css --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@semantic-release/git": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@testing-library/react": "^16.3.2",
    "@types/debug": "^4.1.13",
    "@types/ejs": "^3.1.5",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sprintf-js": "^1.1.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "eslint": "^10.2.0",
    "eslint-plugin-perfectionist": "^5.8.0",
    "happy-dom": "^20.9.0",
    "html-minifier-terser": "^7.2.0",
    "http-server": "^14.1.1",
    "jiti": "^2.6.1",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "stylelint": "^17.7.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "debug": "^4.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.1",
    "sprintf-js": "^1.1.3"
  }
}
